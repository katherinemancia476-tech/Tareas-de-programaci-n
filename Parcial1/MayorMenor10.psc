Proceso MayorMenor
	
    Definir n1, n2 Como Entero
	
    Escribir "Pon el primer número:"
    Leer n1
	
    Escribir "Pon el segundo número:"
    Leer n2
	
    Si n1 > n2 Entonces
        Escribir "Mayor:", n1
        Escribir "Menor:", n2
    SiNo
        Si n2 > n1 Entonces
            Escribir "Mayor:", n2
            Escribir "Menor:", n1
        SiNo
            Escribir "Ambos números son iguales:", n1
        FinSi
    FinSi
	
FinProceso
